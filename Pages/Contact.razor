@page "/contact"
@using System.Net.Http
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Contact Me</PageTitle>

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-8 offset-md-2 text-center">
            <h1 class="mb-4 fw-bold">Let's Work Together</h1>
            <p class="lead mb-5 text-muted">
                Buddy, one click can change everything. If you are ready to transform your vision into a powerful, functional, 
                and high-performing website or AI software application, just tap the button below to get started today!
            </p>
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm h-100 border-0 bg-light">
                <div class="card-body p-4">
                    <h4 class="card-title fw-bold mb-4">Why Hire Me?</h4>
                    <ul class="list-unstyled mb-4">
                        <li class="mb-3"><i class="bi bi-star-fill text-warning me-2"></i>Experienced Web-site Builder</li>
                        <li class="mb-3"><i class="bi bi-star-fill text-warning me-2"></i>Milestone-based orders</li>
                        <li class="mb-3"><i class="bi bi-star-fill text-warning me-2"></i>Quality Work & On-time Delivery</li>
                        <li class="mb-3"><i class="bi bi-star-fill text-warning me-2"></i>Free Support for 30 Days</li>
                    </ul>
                    
                    <hr class="my-4" />

                    <h5 class="fw-bold mb-4">Contact Information</h5>
                    
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-envelope-fill text-primary fs-3 me-3"></i>
                        <div>
                            <h6 class="mb-0 fw-bold">Email</h6>
                            <a href="mailto:kulsoomzuhair@hotmail.com" class="text-decoration-none text-muted">kulsoomzuhair@hotmail.com</a>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-linkedin text-primary fs-3 me-3"></i>
                        <div>
                            <h6 class="mb-0 fw-bold">LinkedIn</h6>
                            <a href="https://www.linkedin.com/in/kulsoom210/" class="text-decoration-none text-muted" target="_blank">linkedin.com/in/kulsoom210</a>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-center">
                        <i class="bi bi-github text-primary fs-3 me-3"></i>
                        <div>
                            <h6 class="mb-0 fw-bold">GitHub</h6>
                            <a href="https://github.com/kulsoomzuhair" class="text-decoration-none text-muted" target="_blank">github.com/kulsoomzuhair</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-7 mb-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4">Send a Message</h4>
                    
                    @if (isSubmitted)
                    {
                        <div class="alert alert-success" role="alert">
                            <h5 class="alert-heading"><i class="bi bi-check-circle-fill me-2"></i>Message Sent!</h5>
                            <p class="mb-0">Thank you for reaching out. I will get back to you at <strong>@contactModel.Email</strong> as soon as possible.</p>
                        </div>
                        <button class="btn btn-outline-primary mt-3" @onclick="ResetForm">Send Another Message</button>
                    }
                    else
                    {
                        <EditForm Model="@contactModel" OnValidSubmit="HandleValidSubmit">
                            <DataAnnotationsValidator />
                            
                            <div class="mb-3">
                                <label for="name" class="form-label fw-bold">Name</label>
                                <InputText id="name" class="form-control" @bind-Value="contactModel.Name" placeholder="Your Name" />
                                <ValidationMessage For="@(() => contactModel.Name)" class="text-danger small" />
                            </div>

                            <div class="mb-3">
                                <label for="email" class="form-label fw-bold">Email address</label>
                                <InputText id="email" type="email" class="form-control" @bind-Value="contactModel.Email" placeholder="name@example.com" />
                                <ValidationMessage For="@(() => contactModel.Email)" class="text-danger small" />
                            </div>
                            
                            <div class="mb-3">
                                <label for="subject" class="form-label fw-bold">Subject</label>
                                <InputText id="subject" class="form-control" @bind-Value="contactModel.Subject" placeholder="Project Inquiry" />
                                <ValidationMessage For="@(() => contactModel.Subject)" class="text-danger small" />
                            </div>

                            <div class="mb-4">
                                <label for="message" class="form-label fw-bold">Message</label>
                                <InputTextArea id="message" class="form-control" rows="5" @bind-Value="contactModel.Message" placeholder="Tell me about your project..." />
                                <ValidationMessage For="@(() => contactModel.Message)" class="text-danger small" />
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                    <span> Sending...</span>
                                }
                                else
                                {
                                    <span>Send Message</span>
                                }
                            </button>
                        </EditForm>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private ContactFormModel contactModel = new();
    private bool isSubmitted = false;
    private bool isSubmitting = false;

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        var response = await Http.PostAsJsonAsync("api/email", contactModel);
        if (response.IsSuccessStatusCode)
        {
            isSubmitted = true;
        }
        else
        {
            // Handle error case
        }
        isSubmitting = false;
    }
    
    private void ResetForm()
    {
        contactModel = new();
        isSubmitted = false;
    }

    public class ContactFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required")]
        public string Name { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email format")]
        public string Email { get; set; } = string.Empty;
        
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Subject is required")]
        public string Subject { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Message is required")]
        public string Message { get; set; } = string.Empty;
    }
}