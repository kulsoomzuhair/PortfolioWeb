@page "/projects"

<PageTitle>Featured Projects | Kulsoom Fatima</PageTitle>

<div class="container mt-5 mb-5">
    <div class="row mb-5">
        <div class="col-lg-8 offset-lg-2 text-center">
            <span class="badge bg-primary-subtle text-primary mb-3 px-3 py-2">My Portfolio</span>
            <h1 class="display-5 fw-bold mb-3">Featured Projects</h1>
            <p class="lead text-secondary">
                A selection of applications, custom integrations, and software systems built for clients, gigs, and academic demonstration.
            </p>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 g-4 justify-content-center">
        <!-- Project 1: Surveillance Tracking -->
        <div class="col">
            <div class="card h-100 border-0">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h4 class="fw-bold mb-0">🔒 Surveillance Tracking System</h4>
                            <span class="badge bg-primary-subtle text-primary">Client Project</span>
                        </div>
                        <p class="text-secondary small mb-3">
                            A robust web application to streamline and automate surveillance workflows. Empowers organizations to efficiently track, verify, and manage surveillance activities ensuring compliance.
                        </p>
                        <ul class="text-secondary small mb-4">
                            <li>Dynamic Workflow with role-based management (Verifiers, Approvers).</li>
                            <li>State tracking (Draft, Active, Inactive) and audit trails.</li>
                            <li>Built-in validation for safety basis-related fields.</li>
                        </ul>
                    </div>
                    <div>
                        <span class="tech-pill">Blazor (.NET 8)</span>
                        <span class="tech-pill">Clean Architecture</span>
                        <span class="tech-pill">SQL Server</span>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Project 2: Blazor Ecommerce -->
        <div class="col">
            <div class="card h-100 border-0">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h4 class="fw-bold mb-0">🛍️ Blazor Ecommerce Web App</h4>
                            <span class="badge bg-success-subtle text-success">Fiverr Gig</span>
                        </div>
                        <p class="text-secondary small mb-3">
                            A full‑featured ecommerce platform showcasing a clean, scalable architecture with a responsive, mobile‑friendly UI.
                        </p>
                        <ul class="text-secondary small mb-4">
                            <li>Secure authentication and ASP.NET Core Identity integration.</li>
                            <li>Shopping cart and order management functionalities.</li>
                            <li>Mock payment integration for seamless checkout simulation.</li>
                        </ul>
                    </div>
                    <div>
                        <span class="tech-pill">Blazor (.NET 9)</span>
                        <span class="tech-pill">C# 13</span>
                        <span class="tech-pill">ASP.NET Core Identity</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Project 3: VigilancePro -->
        <div class="col">
            <div class="card h-100 border-0">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h4 class="fw-bold mb-0">🌐 VigilancePro Case Management</h4>
                            <span class="badge bg-success-subtle text-success">Fiverr Gig</span>
                        </div>
                        <p class="text-secondary small mb-3">
                            A secure case management system built for intelligence and investigation professionals to handle sensitive operations and workflows.
                        </p>
                        <ul class="text-secondary small mb-4">
                            <li>Role-based access control for Admins and Agents.</li>
                            <li>Central dashboard, case file management, and secure evidence vault.</li>
                            <li>Designed for secure information handling.</li>
                        </ul>
                    </div>
                    <div class="d-flex flex-column gap-3">
                        <div>
                            <span class="tech-pill">.NET 8 Blazor Server</span>
                            <span class="tech-pill">Modular Monolith</span>
                            <span class="tech-pill">Entity Framework</span>
                        </div>
                        <a href="https://github.com/kulsoomzuhair/VigilancePro" target="_blank" class="btn btn-outline-secondary w-100 py-2 d-flex align-items-center justify-content-center gap-2">
                            <i class="bi bi-github"></i>
                            <span>View Source Code</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Project 4: AI Software -->
        <div class="col">
            <div class="card h-100 border-0">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h4 class="fw-bold mb-0">🤖 AI Website & Software</h4>
                            <span class="badge bg-success-subtle text-success">Fiverr Gig</span>
                        </div>
                        <p class="text-secondary small mb-3">
                            Providing expert services to transform AI visions into fully functional, high-performing AI websites and software applications.
                        </p>
                        <ul class="text-secondary small mb-4">
                            <li>Built custom AI websites and intuitive AI chatbots.</li>
                            <li>Developed responsive SaaS applications.</li>
                            <li>Transformed Figma/PSD designs into pixel‑perfect code.</li>
                        </ul>
                    </div>
                    <div>
                        <span class="tech-pill">React</span>
                        <span class="tech-pill">Node.js</span>
                        <span class="tech-pill">Python</span>
                        <span class="tech-pill">OpenAI GPT</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Project 5: Traffic Signal -->
        <div class="col">
            <div class="card h-100 border-0">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h4 class="fw-bold mb-0">🚦 Traffic Signal Management</h4>
                            <span class="badge bg-info-subtle text-info">Academic Project</span>
                        </div>
                        <p class="text-secondary small mb-3">
                            An academic project demonstrating problem-solving and logic building through visual representation.
                        </p>
                        <ul class="text-secondary small mb-4">
                            <li>Automated traffic light control logic.</li>
                            <li>Graphical road and traffic simulation.</li>
                        </ul>
                    </div>
                    <div>
                        <span class="tech-pill">C#</span>
                        <span class="tech-pill">WinForms</span>
                        <span class="tech-pill">Visual Studio</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Call to Action -->
    <div class="mt-5 text-center p-5 bg-white rounded shadow-sm border border-light glass-card">
        <h3 class="fw-bold mb-3">Ready to transform your vision?</h3>
        <p class="lead text-secondary mb-4 col-lg-8 offset-lg-2">
            Let's build a custom solution together, perfectly tailored to your business needs, timelines, and technical requirements.
        </p>
        <a href="contact" class="btn btn-primary btn-lg px-5 py-3">Start a Project Today</a>
    </div>
</div>