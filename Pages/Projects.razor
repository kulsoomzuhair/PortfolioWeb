<!-- Premium Video Modal Popup Overlay -->
@if (isModalOpen)
{
    <div class="video-modal-backdrop" @onclick="CloseModal">
        <div class="video-modal-content" @onclick:stopPropagation>
            <button class="video-modal-close" @onclick="CloseModal" aria-label="Close">
                <i class="bi bi-x-lg"></i>
            </button>
            <video id="modalVideo" @key="activeVideoUrl" src="@activeVideoUrl" controls autoplay playsinline class="w-100 h-100"
                   onerror="document.getElementById('video-error-msg').innerText = 'Video Error Code: ' + (this.error ? this.error.code : 'unknown') + ' (1=Aborted, 2=Network, 3=Decode, 4=Not Supported). Message: ' + (this.error ? this.error.message : 'unknown')"></video>
            <div id="video-error-msg" style="color: #ff4a4a; font-weight: bold; text-align: center; position: absolute; bottom: 60px; left: 0; right: 0; background: rgba(0,0,0,0.7); padding: 8px; z-index: 1130;"></div>
        </div>
    </div>
}

@code {
    private bool isModalOpen = false;
    private string activeVideoUrl = string.Empty;

    private void OpenVideoModal(string videoUrl)
    {
        Console.WriteLine($"[DIAGNOSTIC] OpenVideoModal clicked! URL: {videoUrl}");
        activeVideoUrl = videoUrl;
        isModalOpen = true;
        Console.WriteLine($"[DIAGNOSTIC] isModalOpen is now: {isModalOpen}");

        // Trigger an async fetch check to see what the server is returning
        _ = Task.Run(async () =>
        {
            try
            {
                var response = await Http.GetAsync(videoUrl);
                Console.WriteLine($"[DIAGNOSTIC FETCH] Status Code: {response.StatusCode} ({(int)response.StatusCode})");
                Console.WriteLine($"[DIAGNOSTIC FETCH] Content Type: {response.Content.Headers.ContentType?.ToString()}");
                Console.WriteLine($"[DIAGNOSTIC FETCH] Content Length: {response.Content.Headers.ContentLength}");
                if (response.IsSuccessStatusCode)
                {
                    var bytes = await response.Content.ReadAsByteArrayAsync();
                    if (bytes.Length > 0)
                    {
                        var previewLength = Math.Min(200, bytes.Length);
                        var firstChars = System.Text.Encoding.UTF8.GetString(bytes, 0, previewLength);
                        // Clean up control characters for safe printing
                        var cleanChars = new string(firstChars.Select(c => char.IsControl(c) && c != '\r' && c != '\n' && c != '\t' ? '?' : c).ToArray());
                        Console.WriteLine($"[DIAGNOSTIC FETCH] First {previewLength} bytes as text: {cleanChars.Substring(0, Math.Min(cleanChars.Length, 150))}");
                    }
                }

                // Check if the server supports Range Requests
                var rangeRequest = new HttpRequestMessage(HttpMethod.Get, videoUrl);
                rangeRequest.Headers.Range = new System.Net.Http.Headers.RangeHeaderValue(0, 100);
                var rangeResponse = await Http.SendAsync(rangeRequest);
                Console.WriteLine($"[DIAGNOSTIC RANGE FETCH] Status Code: {rangeResponse.StatusCode} ({(int)rangeResponse.StatusCode})");
                Console.WriteLine($"[DIAGNOSTIC RANGE FETCH] Content-Range Header Present: {rangeResponse.Content.Headers.Contains("Content-Range")}");
                if (rangeResponse.Content.Headers.Contains("Content-Range"))
                {
                    Console.WriteLine($"[DIAGNOSTIC RANGE FETCH] Content-Range: {string.Join(", ", rangeResponse.Content.Headers.GetValues("Content-Range"))}");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[DIAGNOSTIC FETCH] Exception occurred: {ex.Message}");
            }
        });
    }

    private void CloseModal()
    {
        Console.WriteLine("[DIAGNOSTIC] CloseModal called.");
        isModalOpen = false;
        activeVideoUrl = string.Empty;
    }
}