@page "/"

<PageTitle>Home | Kulsoom Fatima - Expert Full Stack Developer</PageTitle>

<div class="container mt-5">
    <!-- Hero Section -->
    <div class="row align-items-center mb-5 pb-5 g-5">
        <div class="col-lg-7 text-center text-lg-start">
            <span class="badge bg-primary-subtle text-primary mb-3 px-3 py-2">Available for Freelance & Projects</span>
            <h1 class="display-3 fw-bold mb-3 lh-sm">
                Hi, I'm <span class="gradient-text">Kulsoom Fatima</span>
            </h1>
            <h2 class="h3 text-secondary fw-normal mb-4">
                Expert Full Stack Developer | Custom Websites & Scalable AI Solutions
            </h2>
            
            <p class="lead text-secondary mb-4 pe-lg-5">
                Experienced .NET developer specializing in full‑stack web applications with ASP.NET Core, MVC5, and Blazor. 
                Passionate about building scalable, high‑performance solutions that align with business goals. 
                Skilled in database management, API integration, and AI‑powered applications, delivering end‑to‑end solutions tailored to client needs.
            </p>
            
            <div class="d-flex flex-wrap justify-content-center justify-content-lg-start gap-3">
                <a href="projects" class="btn btn-primary btn-lg px-4 py-3">View My Work</a>
                <a href="contact" class="btn btn-outline-secondary btn-lg px-4 py-3">Get in Touch</a>
            </div>
        </div>
        
        <div class="col-lg-5 text-center">
            <div class="profile-img-container">
                <img src="images/profile.jpg" alt="Kulsoom Fatima" class="img-fluid rounded-circle shadow-lg profile-img" style="max-width: 300px; object-fit: cover; aspect-ratio: 1/1;" />
            </div>
        </div>
    </div>

    <!-- Features / Skill Areas -->
    <div class="row g-4 mt-4 pt-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 p-3">
                <div class="card-body">
                    <div class="contact-icon-wrapper mb-4">
                        <i class="bi bi-laptop"></i>
                    </div>
                    <h4 class="card-title fw-bold mb-3">Web Development</h4>
                    <p class="card-text text-secondary">
                        Building robust and scalable web applications using ASP.NET Core, MVC5, Blazor, and modern JavaScript frameworks.
                    </p>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card h-100 border-0 p-3">
                <div class="card-body">
                    <div class="contact-icon-wrapper mb-4" style="color: #a855f7; background: rgba(168, 85, 247, 0.08);">
                        <i class="bi bi-robot"></i>
                    </div>
                    <h4 class="card-title fw-bold mb-3">AI Solutions</h4>
                    <p class="card-text text-secondary">
                        Crafting customized AI websites, intuitive AI chatbots, automation tools, and transforming your AI vision into reality.
                    </p>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card h-100 border-0 p-3">
                <div class="card-body">
                    <div class="contact-icon-wrapper mb-4" style="color: #1dbf73; background: rgba(29, 191, 115, 0.08);">
                        <i class="bi bi-server"></i>
                    </div>
                    <h4 class="card-title fw-bold mb-3">API & Backend</h4>
                    <p class="card-text text-secondary">
                        Designing secure, scalable backend architectures with SQL Server, MongoDB, JWT Auth, and RESTful APIs.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>