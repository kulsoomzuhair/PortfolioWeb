@page "/"

<PageTitle>Home | Kulsoom Fatima</PageTitle>

<div class="container mt-5">
    <div class="row align-items-center mb-5">
        <div class="col-md-4 text-center mb-4 mb-md-0">
            <img src="images/profile.jpg" alt="Kulsoom Fatima" class="img-fluid rounded-circle shadow-lg profile-img" style="max-width: 250px; border: 5px solid white; object-fit: cover; aspect-ratio: 1/1;" onerror="this.onerror=null; this.src='https://via.placeholder.com/250x250.png?text=Kulsoom+Fatima';" />
        </div>
        <div class="col-md-8 text-center text-md-start">
            <h1 class="display-4 fw-bold">Hi, I'm Kulsoom Fatima</h1>
            <h2 class="h3 text-muted mt-3 mb-4">Expert Full Stack Developer | Custom Websites & Scalable AI Solutions</h2>
            
            <p class="lead text-muted mb-4">
                Experienced .NET developer specializing in full‑stack web applications with ASP.NET Core, MVC5, and Blazor. 
                Passionate about building scalable, high‑performance solutions that align with business goals. 
                Skilled in database management, API integration, and AI‑powered applications, delivering end‑to‑end solutions tailored to client needs.
            </p>
            
            <div>
                <a href="projects" class="btn btn-primary btn-lg me-3 px-4 py-2">View My Work</a>
                <a href="contact" class="btn btn-outline-secondary btn-lg px-4 py-2">Get in Touch</a>
            </div>
        </div>
    </div>

    <div class="row mt-5 pt-4 text-start">
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-laptop display-6 text-primary"></i>
                    </div>
                    <h5 class="card-title fw-bold">Web Development</h5>
                    <p class="card-text text-muted">Building robust and scalable web applications using ASP.NET Core, MVC5, Blazor, and modern JavaScript frameworks.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-robot display-6 text-primary"></i>
                    </div>
                    <h5 class="card-title fw-bold">AI Solutions</h5>
                    <p class="card-text text-muted">Crafting customized AI websites, intuitive AI chatbots, automation tools, and transforming your AI vision into reality.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="bi bi-server display-6 text-primary"></i>
                    </div>
                    <h5 class="card-title fw-bold">API & Backend</h5>
                    <p class="card-text text-muted">Designing secure, scalable backend architectures with SQL Server, MongoDB, JWT Auth, and RESTful APIs.</p>
                </div>
            </div>
        </div>
    </div>
</div>