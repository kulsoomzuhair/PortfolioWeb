@page "/about"

<PageTitle>About Me</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-10 offset-lg-1">
            <h1 class="mb-4 fw-bold">About Me</h1>
            
            <p class="lead text-muted mb-5">
                I am an experienced .NET developer specializing in full-stack web application development using modern frameworks like ASP.NET Core, MVC5, Blazor. 
                My passion lies in building high-performance, scalable applications that meet business objectives while ensuring long-term maintainability. 
                With expertise in database management, API integration, and frontend technologies, I provide end-to-end solutions tailored to client needs.
            </p>

            <h3 class="mt-5 mb-4 fw-bold">Core Skills & Tech Stack</h3>
            
            <div class="row g-4 mb-5">
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <h5 class="card-title fw-bold text-primary mb-3"><i class="bi bi-code-slash me-2"></i>Frontend & Design</h5>
                            <p class="card-text">React Native, React JS, Tailwind CSS, SignalR, Stripe Elements, Responsive UI, Figma/PSD to Code conversion.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <h5 class="card-title fw-bold text-primary mb-3"><i class="bi bi-hdd-network me-2"></i>Backend & Frameworks</h5>
                            <p class="card-text">ASP.NET Core 8, MVC5, Blazor (.NET 8/9), Entity Framework Core, JWT Auth, Swagger, Serilog.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <h5 class="card-title fw-bold text-primary mb-3"><i class="bi bi-robot me-2"></i>AI & Programming</h5>
                            <p class="card-text">OpenAI GPT, PyTorch, TensorFlow. JavaScript (React, Node.js, Next.js), Python (Django, Flask).</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body">
                            <h5 class="card-title fw-bold text-primary mb-3"><i class="bi bi-database me-2"></i>Databases & APIs</h5>
                            <p class="card-text">SQL Server, MySQL, PostgreSQL, MongoDB. REST APIs, GraphQL, AI API Integrations.</p>
                        </div>
                    </div>
                </div>
            </div>

            <h3 class="mt-5 mb-4 fw-bold">What I Offer</h3>
            <div class="card shadow-sm border-0 bg-light mb-5">
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-unstyled mb-0">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>AI Website & Software Development</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Full-Stack Web Development</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>AI-Powered Chatbots & Automation</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Custom SaaS Applications</li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i>E-commerce Functionality</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled mb-0">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Payment Gateway Integration</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Responsive Figma/PSD to Code</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>SEO-Friendly & Fast-Loading sites</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>API Development & Third-Party Integrations</li>
                                <li><i class="bi bi-check-circle-fill text-success me-2"></i>30 Days Free Support After Completion</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>